{
  "name": "dataprofile-cloudflare",
  "version": "1.0.0",
  "private": true,
  "description": "Pulumi (TypeScript) program for the durable Cloudflare infrastructure of DataProfile. The Worker/Pages compute + its bindings stay owned by wrangler.",
  "main": "index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "cf:up": "zsh ./cf-levantar.zsh",
    "cf:preview": "zsh ./cf-levantar.zsh --preview-only",
    "cf:verify": "zsh ./cf-verificar.zsh",
    "cf:audit": "zsh ./cf-audit.zsh"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@pulumi/cloudflare": "^6.0.0",
    "@pulumi/pulumi": "^3.140.0"
  }
}
